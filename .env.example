# Copy to .env for local overrides. Never commit the real .env.

# Generate a strong key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=dev-insecure-key-change-me-in-production-0123456789abcdef

# Turn OFF in production.
DEBUG=True

# Comma-separated hostnames allowed to serve the app in production.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated https origins, e.g. https://your-app.example.com
CSRF_TRUSTED_ORIGINS=

# Enable only behind a trusted reverse proxy that manages X-Forwarded-For.
TRUST_X_FORWARDED_FOR=False

# IANA time zone used for "due today" and streak calculations.
TIME_ZONE=America/Los_Angeles

# Production PostgreSQL connection URL.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: absolute path for the SQLite database file.
# DATABASE_PATH=/data/db.sqlite3
